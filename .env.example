# image-gen — environment configuration
#
# Copy this file to `.env` in the package root and fill in your values.
# The CLI loads `.env` from this package directory automatically; shell env
# variables always take precedence over .env values.

# Required for the default `grok` and `grok-pro` presets.
# Get a key at https://console.x.ai/
XAI_API_KEY=

# Required only for `flux-pro`, legacy OpenRouter aliases, or OpenRouter
# vendor/slug pass-through models. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Override the xAI API base URL (defaults to https://api.x.ai/v1).
# Only useful for testing against a proxy.
#XAI_BASE_URL=

# Optional. Override the OpenRouter API base URL (defaults to
# https://openrouter.ai/api/v1). Only useful for testing against a proxy.
#OPENROUTER_BASE_URL=

# Optional. Default model alias, xAI model ID, or OpenRouter vendor/slug used
# when requests omit `model`. Defaults to `grok` (grok-imagine-image).
#IMAGE_GEN_DEFAULT_MODEL=grok

# Optional. Default output directory when requests omit `output` / `output_dir`.
# Defaults to `./generated` relative to the current working directory.
#IMAGE_GEN_OUTPUT_DIR=./generated

# Optional. OpenRouter attribution headers. These are sent with every request
# to credit the calling tool in OpenRouter's dashboards. Defaults are
# tool-appropriate; override if you want your own attribution.
#OPENROUTER_HTTP_REFERER=https://github.com/AidenGeunGeun/image-gen
#OPENROUTER_TITLE=image-gen
